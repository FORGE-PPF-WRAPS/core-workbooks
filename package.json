{
  "name": "skill-forge-core-workbooks",
  "version": "1.0.0",
  "description": "Skill Forge core training workbooks, SOPs, and operational documents",
  "private": true,
  "scripts": {
    "build": "node scripts/build-workbooks.js",
    "build:pdf": "node scripts/build-workbooks.js --pdf",
    "build:branded": "node scripts/build-workbooks.js --branded",
    "build:branded:pdf": "node scripts/build-workbooks.js --branded --pdf",
    "build:docs": "node scripts/build-docs.js",
    "build:docs:pdf": "node scripts/build-docs.js --pdf",
    "build:docs:branded": "node scripts/build-docs.js --branded",
    "build:docs:branded:pdf": "node scripts/build-docs.js --branded --pdf",
    "generate:manuals": "node scripts/generate-manuals/index.js",
    "generate:sops": "node scripts/generate-sops.js",
    "build:manuals": "node scripts/build-manuals.js",
    "build:manuals:pdf": "node scripts/build-manuals.js --pdf",
    "build:manuals:branded": "node scripts/build-manuals.js --branded",
    "build:manuals:branded:pdf": "node scripts/build-manuals.js --branded --pdf",
    "build:library": "node scripts/build-library.js",
    "build:library:copy": "node scripts/build-library.js --copy-only",
    "build:all:branded:pdf": "npm run build:branded:pdf && npm run build:docs:branded:pdf && npm run build:manuals:branded:pdf",
    "build:all": "npm run build && npm run build:docs",
    "build:all:pdf": "npm run build:pdf && npm run build:docs:pdf && npm run build:manuals:pdf"
  },
  "dependencies": {
    "marked": "^15.0.0",
    "puppeteer": "^25.3.0",
    "qrcode": "^1.5.4"
  }
}
